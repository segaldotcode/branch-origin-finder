{
  "name": "branch-origin-finder",
  "version": "0.1.1",
  "description": "CLI and web tool that infers the most likely parent branch of any Git branch using merge-base analysis, reflog and confidence scoring.",
  "keywords": ["git", "cli", "branch", "merge-base", "reflog", "developer-tools"],
  "license": "MIT",
  "author": "Segal G.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/segaldotcode/branch-origin-finder.git"
  },
  "homepage": "https://github.com/segaldotcode/branch-origin-finder#readme",
  "bugs": {
    "url": "https://github.com/segaldotcode/branch-origin-finder/issues"
  },
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "branch-origin": "./dist/cli.js"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cli": "tsup && node scripts/prepare-npm-package.mjs",
    "start": "next start",
    "lint": "eslint",
    "branch-origin": "tsx bin/branch-origin.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^15.0.0",
    "cuelume": "^0.1.2",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.13.1",
    "simple-git": "^3.36.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
